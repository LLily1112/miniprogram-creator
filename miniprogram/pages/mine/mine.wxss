.mine-container {
  height: 100vh;
  position: relative;
}

.scroll-container {
  height: 100vh;
  position: relative;
}

.user-header {
  position: relative;
  padding: 60rpx 32rpx 40rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: -50%;
  width: 200%;
  height: 100%;
  background: linear-gradient(135deg, #F0FFF4 0%, #EBF8FF 30%, #FFF5E6 60%, #FFE5E5 100%);
}

.header-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-container {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  border: 4rpx solid rgba(255, 107, 107, 0.3);
}

.avatar-icon {
  font-size: 72rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3748;
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 26rpx;
  color: #718096;
  margin-bottom: 32rpx;
}

.quick-stats {
  display: flex;
  align-items: center;
  gap: 48rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D3748;
}

.stat-label {
  font-size: 24rpx;
  color: #718096;
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background-color: #E5E7EB;
}

.content-section {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

.menu-card {
  background-color: #ffffff;
  border-radius: 28rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  margin-bottom: 8rpx;
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.menu-item:last-child {
  margin-bottom: 0;
}

.menu-item:active {
  background-color: rgba(255, 107, 107, 0.05);
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-icon.purple {
  background-color: rgba(147, 51, 234, 0.1);
}

.menu-icon.blue {
  background-color: rgba(59, 130, 246, 0.1);
}

.menu-icon.green {
  background-color: rgba(34, 197, 94, 0.1);
}

.menu-icon.orange {
  background-color: rgba(249, 115, 22, 0.1);
}

.menu-icon.pink {
  background-color: rgba(236, 72, 153, 0.1);
}

.menu-icon.yellow {
  background-color: rgba(234, 179, 8, 0.1);
}

.menu-content {
  flex: 1;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3748;
  margin-bottom: 4rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #718096;
}

.menu-arrow {
  font-size: 32rpx;
  color: #D1D5DB;
}

.profile-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.modal-content {
  width: 100%;
  background-color: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  padding-bottom: 120rpx;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3748;
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  background-color: #F3F4F6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #6B7280;
}

.modal-body-scroll {
  height: 60vh;
}

.modal-body {
  padding: 32rpx;
  padding-bottom: 120rpx;
}

.form-section {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3748;
  margin-bottom: 16rpx;
  display: block;
}

.form-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.option-btn {
  padding: 16rpx 28rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: 2rpx solid #E5E7EB;
  background-color: #ffffff;
  color: #4B5563;
}

.option-btn.active {
  background: linear-gradient(135deg, #FF6B6B 0%, #FFA07A 100%);
  color: #ffffff;
  border-color: #FF6B6B;
}

.save-btn {
  width: 100%;
  background: linear-gradient(135deg, #FF6B6B 0%, #FFA07A 100%);
  color: #ffffff;
  border: none;
  border-radius: 48rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
}

.about-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.about-content {
  width: 85%;
  background-color: #ffffff;
  border-radius: 28rpx;
  padding: 48rpx 32rpx;
  text-align: center;
}

.about-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.about-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3748;
  margin-bottom: 12rpx;
}

.about-version {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-bottom: 24rpx;
}

.about-desc {
  font-size: 28rpx;
  color: #6B7280;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.about-btn {
  width: 100%;
  background-color: #F3F4F6;
  color: #2D3748;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.custom-input-wrap {
  margin-top: 20rpx;
}

.custom-input {
  width: 100%;
  padding: 20rpx 28rpx;
  border: 2rpx solid #E5E7EB;
  border-radius: 24rpx;
  font-size: 28rpx;
  background-color: #FAFAFA;
}

.keyword-input-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.keyword-input {
  flex: 1;
  padding: 20rpx 28rpx;
  border: 2rpx solid #E5E7EB;
  border-radius: 24rpx;
  font-size: 28rpx;
  background-color: #FAFAFA;
}

.add-keyword-btn {
  padding: 20rpx 32rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FFA07A 100%);
  color: #ffffff;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  white-space: nowrap;
}

.keyword-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.keyword-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background-color: #F3F4F6;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #4B5563;
}

.tag-delete {
  color: #9CA3AF;
  font-size: 28rpx;
  font-weight: bold;
}
