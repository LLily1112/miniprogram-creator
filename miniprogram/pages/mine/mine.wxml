<view class="mine-container">
  <view class="user-header">
    <view class="header-bg"></view>
    <view class="header-content">
      <view class="avatar-container">
        <text class="avatar-icon">👤</text>
      </view>
      <text class="user-name">{{userProfile ? userProfile.nickname : '自媒体创作者'}}</text>
      <text class="user-desc">{{profile && profile.identity ? profile.identity : (profile && profile.customIdentity ? profile.customIdentity : '选择你的身份')}}</text>

      <view class="quick-stats">
        <view class="stat-item">
          <text class="stat-value">{{stats.stories}}</text>
          <text class="stat-label">故事</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{stats.scripts}}</text>
          <text class="stat-label">脚本</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-value">{{stats.analyses}}</text>
          <text class="stat-label">分析</text>
        </view>
      </view>
    </view>
  </view>

  <view class="content-section">
    <view class="menu-card">
      <view class="menu-item" bindtap="editProfile">
        <view class="menu-icon purple">👤</view>
        <view class="menu-content">
          <text class="menu-title">编辑个人画像</text>
          <text class="menu-desc">设置身份标签、兴趣关键词</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="goToScripts">
        <view class="menu-icon blue">📄</view>
        <view class="menu-content">
          <text class="menu-title">我的脚本库</text>
          <text class="menu-desc">查看和管理已保存的脚本</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="goToAnalytics">
        <view class="menu-icon green">📊</view>
        <view class="menu-content">
          <text class="menu-title">数据分析</text>
          <text class="menu-desc">AI分析视频数据，优化内容</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-card">
      <view class="menu-item" bindtap="goToSettings">
        <view class="menu-icon orange">⚙️</view>
        <view class="menu-content">
          <text class="menu-title">API设置</text>
          <text class="menu-desc">配置DeepSeek API密钥</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="clearCache">
        <view class="menu-icon pink">🗑️</view>
        <view class="menu-content">
          <text class="menu-title">清理缓存</text>
          <text class="menu-desc">清除本地存储数据</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>

      <view class="menu-item" bindtap="showAbout">
        <view class="menu-icon yellow">ℹ️</view>
        <view class="menu-content">
          <text class="menu-title">关于我们</text>
          <text class="menu-desc">版本信息和使用说明</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view wx:if="{{showProfileModal}}" class="profile-modal" bindtap="closeProfileModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">编辑个人画像</text>
        <view class="close-btn" bindtap="closeProfileModal">×</view>
      </view>
      <scroll-view scroll-y class="modal-body-scroll">
        <view class="modal-body">
          <view class="form-section">
            <text class="form-label">身份标签</text>
            <view class="form-options">
              <view
                wx:for="{{identityOptions}}"
                wx:key="*this"
                class="option-btn {{profile && profile.identity === item ? 'active' : ''}}"
                bindtap="setIdentity"
                data-value="{{item}}"
              >
                {{item}}
              </view>
            </view>
            <view class="custom-input-wrap">
              <input
                class="custom-input"
                placeholder="或输入自定义身份..."
                value="{{profile.customIdentity}}"
                bindinput="onCustomIdentityInput"
              />
            </view>
          </view>

          <view class="form-section">
            <text class="form-label">年龄区间</text>
            <view class="form-options">
              <view
                wx:for="{{ageOptions}}"
                wx:key="*this"
                class="option-btn {{profile && profile.ageRange === item ? 'active' : ''}}"
                bindtap="setAgeRange"
                data-value="{{item}}"
              >
                {{item}}
              </view>
            </view>
          </view>

          <view class="form-section">
            <text class="form-label">所在城市</text>
            <view class="form-options">
              <view
                wx:for="{{cityOptions}}"
                wx:key="*this"
                class="option-btn {{profile && profile.cityLevel === item ? 'active' : ''}}"
                bindtap="setCityLevel"
                data-value="{{item}}"
              >
                {{item}}
              </view>
            </view>
          </view>

          <view class="form-section">
            <text class="form-label">兴趣标签（可多选）</text>
            <view class="form-options">
              <view
                wx:for="{{interestOptions}}"
                wx:key="*this"
                class="option-btn {{isInterestSelected(item) ? 'active' : ''}}"
                bindtap="toggleInterest"
                data-value="{{item}}"
              >
                {{item}}
              </view>
            </view>
          </view>

          <view class="form-section">
            <text class="form-label">自定义关键词（最多10个）</text>
            <view class="keyword-input-wrap">
              <input
                class="keyword-input"
                placeholder="输入关键词后点击添加"
                value="{{newKeyword}}"
                bindinput="onKeywordInput"
              />
              <view class="add-keyword-btn" bindtap="addCustomKeyword">+添加</view>
            </view>
            <view wx:if="{{profile.customKeywords.length > 0}}" class="keyword-tags">
              <view
                wx:for="{{profile.customKeywords}}"
                wx:key="*this"
                class="keyword-tag"
              >
                {{item}}
                <text class="tag-delete" bindtap="removeKeyword" data-index="{{index}}">×</text>
              </view>
            </view>
          </view>

          <button class="save-btn" bindtap="saveProfile">💾 保存设置</button>
        </view>
      </scroll-view>
    </view>
  </view>

  <view wx:if="{{showAboutModal}}" class="about-modal" bindtap="closeAboutModal">
    <view class="about-content" catchtap="stopPropagation">
      <text class="about-icon">🎬</text>
      <text class="about-title">自媒体创作助手</text>
      <text class="about-version">版本 1.0.0</text>
      <text class="about-desc">帮助你追踪热点、生成脚本、分析数据，让创作更轻松！</text>
      <button class="about-btn" bindtap="closeAboutModal">知道了</button>
    </view>
  </view>
</view>
