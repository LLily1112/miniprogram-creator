.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.page-header {
  background: linear-gradient(135deg, #1890FF 0%, #096DD9 100%);
  padding: 40rpx 32rpx;
  color: #ffffff;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.page-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

.section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 24rpx;
  margin-top: 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}

.setting-item {
  margin-bottom: 24rpx;
}

.setting-label {
  margin-bottom: 16rpx;
}

.label-title {
  display: block;
  font-size: 28rpx;
  color: #1a1a1a;
  margin-bottom: 4rpx;
}

.label-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

.input-group {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 20rpx;
}

.setting-input {
  flex: 1;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #1a1a1a;
}

.setting-input.password {
  letter-spacing: 4rpx;
}

.toggle-visibility {
  font-size: 36rpx;
  padding: 20rpx;
}

.help-card {
  background-color: #F0F5FF;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 16rpx;
}

.help-card.small {
  padding: 16rpx;
  margin-top: 12rpx;
}

.help-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #1890FF;
  margin-bottom: 16rpx;
}

.help-steps {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.step {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

.help-hint {
  font-size: 24rpx;
  color: #666666;
}

.pricing-info {
  background-color: #FFF9F0;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 16rpx;
}

.info-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #FA8C16;
  margin-bottom: 12rpx;
}

.info-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-item {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

.action-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.btn-save {
  flex: 2;
  padding: 24rpx;
  background: linear-gradient(135deg, #1890FF 0%, #096DD9 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
}

.btn-test {
  flex: 1;
  padding: 24rpx;
  background-color: #ffffff;
  color: #1890FF;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: 2rpx solid #1890FF;
}

.usage-info {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.usage-item {
  display: flex;
  background-color: #FAFAFA;
  border-radius: 12rpx;
  padding: 20rpx;
}

.usage-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.usage-content {
  flex: 1;
}

.usage-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.usage-desc {
  display: block;
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}
