.container {
  height: 100vh;
  position: relative;
}

.scroll-container {
  height: calc(100vh - env(safe-area-inset-bottom));
}

.page-header {
  background: linear-gradient(135deg, #0D4336 0%, #1A5F4A 100%);
  padding: 48rpx 32rpx;
  color: #ffffff;
  border-radius: 0 0 48rpx 48rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.page-desc {
  font-size: 28rpx;
  opacity: 0.85;
}

.section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(13, 67, 54, 0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #0D4336;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.upload-section {
  text-align: center;
}

.upload-tips {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #6B7B76;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.upload-area {
  width: 100%;
  height: 320rpx;
  background-color: #F4F2F1;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.upload-icon {
  font-size: 64rpx;
}

.upload-text {
  font-size: 30rpx;
  color: #0D4336;
  font-weight: 500;
}

.upload-hint {
  font-size: 24rpx;
  color: #6B7B76;
}

.uploaded-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.upload-actions {
  display: flex;
  gap: 20rpx;
}

.btn-outline {
  flex: 1;
  padding: 24rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  background-color: transparent;
  border: 2rpx solid #0D4336;
  color: #0D4336;
}

.btn-primary {
  flex: 2;
  padding: 24rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #CE8A62 0%, #D9A076 100%);
  color: #ffffff;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(206, 138, 98, 0.3);
}

.analysis-loading {
  text-align: center;
  padding: 40rpx;
}

.loading-animation {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #F4F2F1;
  border-top-color: #CE8A62;
  border-radius: 50%;
  animation: spin 1.2s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #6B7B76;
}

.recognized-data-card {
  background-color: #F4F2F1;
  border-radius: 20rpx;
  padding: 28rpx;
}

.data-header {
  margin-bottom: 24rpx;
}

.data-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0D4336;
}

.data-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.data-item {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.data-label {
  font-size: 24rpx;
  color: #6B7B76;
}

.data-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #0D4336;
}

.derived-metrics {
  display: flex;
  gap: 24rpx;
}

.derived-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background-color: rgba(206, 138, 98, 0.1);
  border-radius: 12rpx;
}

.derived-label {
  font-size: 26rpx;
  color: #6B7B76;
}

.derived-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #CE8A62;
}

.analysis-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(13, 67, 54, 0.06);
}

.health-section {
  margin-bottom: 32rpx;
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #0D4336;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.health-overview {
  display: flex;
  align-items: center;
  gap: 40rpx;
}

.health-score-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #CE8A62 0%, #D9A076 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(206, 138, 98, 0.3);
}

.score-num {
  font-size: 56rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1;
}

.score-unit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.health-level {
  font-size: 36rpx;
  font-weight: 700;
  color: #0D4336;
}

.insight-section {
  margin-bottom: 32rpx;
}

.insight-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background-color: #F4F2F1;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.insight-item:last-child {
  margin-bottom: 0;
}

.insight-icon {
  font-size: 36rpx;
}

.insight-content {
  flex: 1;
}

.insight-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0D4336;
  margin-bottom: 8rpx;
}

.insight-text {
  font-size: 26rpx;
  color: #6B7B76;
  line-height: 1.5;
}

.advice-section {
  margin-bottom: 32rpx;
}

.advice-item {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
  background-color: #F4F2F1;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.advice-item:last-child {
  margin-bottom: 0;
}

.advice-priority {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.advice-priority.high {
  background-color: rgba(239, 68, 68, 0.15);
  color: #EF4444;
}

.advice-priority.medium {
  background-color: rgba(249, 115, 22, 0.15);
  color: #F97316;
}

.advice-priority.low {
  background-color: rgba(34, 197, 94, 0.15);
  color: #22C55E;
}

.advice-content {
  flex: 1;
}

.advice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0D4336;
  margin-bottom: 8rpx;
}

.advice-desc {
  font-size: 26rpx;
  color: #6B7B76;
  line-height: 1.5;
}

.empty-history {
  text-align: center;
  padding: 40rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #6B7B76;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background-color: #F4F2F1;
  border-radius: 16rpx;
}

.history-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  object-fit: cover;
}

.history-info {
  flex: 1;
}

.history-title {
  font-size: 28rpx;
  color: #0D4336;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.history-score {
  font-size: 24rpx;
  color: #CE8A62;
}
