.hot-container {
  height: 100vh;
  position: relative;
}

.scroll-container {
  height: calc(100vh - env(safe-area-inset-bottom));
}

.page-header {
  padding: 60rpx 32rpx 32rpx;
  border-radius: 0 0 48rpx 48rpx;
  position: relative;
  overflow: hidden;
}

.page-header::before {
  content: '';
  position: absolute;
  top: 0;
  left: -50%;
  width: 200%;
  height: 100%;
  background: linear-gradient(135deg, #FFE5E5 0%, #FFF0E6 30%, #FFFAF0 60%, #F0FFF4 100%);
}

.page-header-content {
  position: relative;
  z-index: 1;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #2D3748;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.page-title-icon {
  font-size: 40rpx;
}

.header-actions {
  display: flex;
  gap: 16rpx;
}

.refresh-btn {
  width: 72rpx;
  height: 72rpx;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.platform-tabs {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.platform-tab {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background-color: rgba(255, 255, 255, 0.6);
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #718096;
  transition: all 0.3s ease;
}

.platform-tab.active {
  background-color: #FF6B6B;
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.3);
}

.tab-icon {
  font-size: 24rpx;
}

.tab-name {
  font-weight: 500;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  padding: 0 20rpx;
  margin-top: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: #2D3748;
  padding: 0 16rpx;
}

.search-clear {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #9CA3AF;
  margin-right: 8rpx;
}

.search-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #FF6B6B;
}

.header-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.page-desc {
  font-size: 26rpx;
  color: #718096;
}

.update-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #F3F4F6;
  border-top-color: #FF6B6B;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #9CA3AF;
}

.hot-list {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

.hot-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.hot-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.rank-badge {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 26rpx;
  flex-shrink: 0;
}

.rank-badge[data-rank="1"] {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  color: #ffffff;
}

.rank-badge[data-rank="2"] {
  background: linear-gradient(135deg, #C0C0C0 0%, #A0A0A0 100%);
  color: #ffffff;
}

.rank-badge[data-rank="3"] {
  background: linear-gradient(135deg, #CD7F32 0%, #B87333 100%);
  color: #ffffff;
}

.rank-badge[data-rank="4"],
.rank-badge[data-rank="5"],
.rank-badge[data-rank="6"],
.rank-badge[data-rank="7"],
.rank-badge[data-rank="8"],
.rank-badge[data-rank="9"],
.rank-badge[data-rank="10"] {
  background-color: #F3F4F6;
  color: #6B7280;
}

.rank-num {
  font-size: 24rpx;
}

.rank-dot {
  font-size: 32rpx;
  color: #9CA3AF;
}

.hot-content {
  flex: 1;
  min-width: 0;
}

.hot-title-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.hot-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3748;
  line-height: 1.4;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.tag.new {
  background-color: #EBF8FF;
  color: #3182CE;
}

.tag.hot {
  background-color: #FFF5F5;
  color: #FC8181;
}

.hot-desc {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
  display: block;
}

.hot-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.heat-value {
  font-size: 24rpx;
  color: #FF6B6B;
  font-weight: 600;
}

.trend {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.trend-up {
  background-color: #F0FFF4;
  color: #48BB78;
}

.trend-down {
  background-color: #FFF5F5;
  color: #FC8181;
}

.category-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  background-color: #EBF8FF;
  color: #4299E1;
  border-radius: 16rpx;
}

.hot-actions {
  flex-shrink: 0;
}

.collect-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background-color: #F9FAFB;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.collect-btn.collected {
  background-color: #FFF5F5;
}

.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.modal-content {
  width: 100%;
  background-color: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  max-height: 85vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F3F4F6;
  position: sticky;
  top: 0;
  background-color: #ffffff;
  z-index: 1;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3748;
  flex: 1;
}

.close-btn {
  width: 56rpx;
  height: 56rpx;
  background-color: #F3F4F6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #6B7280;
}

.modal-body {
  padding: 24rpx 32rpx 120rpx;
}

.detail-info {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.info-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 20rpx;
  background-color: #F9FAFB;
  border-radius: 16rpx;
}

.info-label {
  font-size: 24rpx;
  color: #9CA3AF;
}

.info-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3748;
}

.info-value.trend-up {
  color: #48BB78;
}

.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3748;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.video-item {
  background-color: #F9FAFB;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.video-title {
  font-size: 28rpx;
  color: #2D3748;
  margin-bottom: 12rpx;
  display: block;
  line-height: 1.5;
}

.video-stats {
  display: flex;
  gap: 24rpx;
}

.stat {
  font-size: 24rpx;
  color: #9CA3AF;
}

.words-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.word-tag {
  padding: 10rpx 24rpx;
  background-color: #F3F4F6;
  color: #4B5563;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.action-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
  position: sticky;
  bottom: 0;
  background-color: #ffffff;
  padding-top: 20rpx;
}

.action-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  background-color: #F3F4F6;
  color: #4B5563;
  border: none;
}

.action-btn.collected {
  background-color: #FFF5F5;
  color: #FF6B6B;
}

.action-btn.primary {
  background: linear-gradient(135deg, #FF6B6B 0%, #FFA07A 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
}
