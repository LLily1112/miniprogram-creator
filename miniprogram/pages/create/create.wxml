<view class="create-container">
  <view class="page-header">
    <view class="page-header-content">
      <view class="page-title">
        <text class="page-title-icon">✨</text>
        <text>智能创作</text>
      </view>
      <text class="page-desc">让AI帮你生成优质脚本</text>
    </view>
  </view>

  <view class="content-section">
    <view class="section">
      <view class="section-title">🔥 选择热点话题</view>
      <view class="topic-selector" bindtap="showTopicPicker">
        <view class="topic-display">
          <text class="topic-text">{{selectedTopic ? selectedTopic.title : '请选择一个话题'}}</text>
          <text class="topic-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <text class="section-title">📝 添加故事素材</text>
        <button class="random-btn" bindtap="onRandomStory">🎲 随机选取</button>
      </view>

      <view wx:if="{{stories.length === 0}}" class="empty-stories">
        <text class="empty-icon">📭</text>
        <text class="empty-text">还没有故事素材</text>
        <navigator url="/pages/story/story" class="add-story-btn">去记录</navigator>
      </view>

      <view wx:else class="stories-list">
        <view wx:for="{{stories}}" wx:key="id" class="story-item">
          <view class="story-checkbox {{item.selected ? 'selected' : ''}}" bindtap="onStoryToggle" data-id="{{item.id}}">
            <text wx:if="{{item.selected}}" class="checkbox-icon">✓</text>
          </view>
          <view class="story-info">
            <text class="story-content-text">{{item.content}}</text>
            <text class="story-date-text">{{item.dateDisplay}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">🎨 选择风格</view>
      <view class="style-selector">
        <view 
          wx:for="{{styles}}" 
          wx:key="*this" 
          class="style-btn {{selectedStyle === item ? 'active' : ''}}"
          bindtap="onStyleChange" 
          data-style="{{item}}"
        >
          {{item}}
        </view>
      </view>
    </view>

    <button class="generate-btn" bindtap="onGenerate" loading="{{isGenerating}}">
      {{isGenerating ? 'AI生成中...' : '🚀 生成脚本'}}
    </button>

    <view wx:if="{{generatedScript}}" class="script-result">
      <view class="script-header">
        <text class="script-title">📄 生成结果</text>
        <view class="script-actions">
          <view class="action-btn" bindtap="copyScript">📋 复制</view>
          <view class="action-btn" bindtap="saveScript">💾 保存</view>
          <view class="action-btn" bindtap="clearScript">🗑️ 清空</view>
        </view>
      </view>
      <view class="golden-sentence">
        <text class="golden-label">🌟 金句</text>
        <text class="golden-text">{{generatedScript.goldenSentence}}</text>
      </view>
      <text class="script-content">{{generatedScript.content}}</text>
      <view class="script-stats">
        <view class="stat-item">
          <text class="stat-label">字数</text>
          <text class="stat-value">{{generatedScript.wordCount}}</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">时长</text>
          <text class="stat-value">{{generatedScript.duration}}秒</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{showPicker}}" class="picker-modal" bindtap="hidePicker">
    <view class="picker-content" catchtap="stopPropagation">
      <view class="picker-header">
        <text class="picker-title">🔥 选择话题</text>
        <view class="picker-close" bindtap="hidePicker">关闭</view>
      </view>
      <scroll-view scroll-y class="topics-scroll">
      <view class="topics-grid">
        <view
          wx:for="{{hotTopics}}"
          wx:key="id"
          class="topic-tag {{selectedTopic && selectedTopic.id === item.id ? 'active' : ''}}"
          bindtap="selectTopic"
          data-topic="{{item}}"
        >
          <text class="topic-name">{{item.title}}</text>
          <text class="topic-hot">{{item.hotValue}}</text>
        </view>
      </view>
      </scroll-view>
    </view>
  </view>
</view>
