.story-container {
  height: 100vh;
  position: relative;
  overflow: hidden;
}

.scroll-container {
  height: 100vh;
  position: relative;
}

.page-header {
  padding: 60rpx 32rpx 40rpx;
  border-radius: 0 0 48rpx 48rpx;
  position: relative;
  overflow: hidden;
}

.page-header::before {
  content: '';
  position: absolute;
  top: 0;
  left: -50%;
  width: 200%;
  height: 100%;
  background: linear-gradient(135deg, #EBF8FF 0%, #F0FFF4 30%, #FFF5E6 60%, #FFE5E5 100%);
}

.page-header-content {
  position: relative;
  z-index: 1;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #2D3748;
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.page-title-icon {
  font-size: 40rpx;
}

.page-desc {
  font-size: 26rpx;
  color: #718096;
}

.content-section {
  padding: 24rpx;
  padding-bottom: 120rpx;
}

.section {
  background-color: #ffffff;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3748;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.char-count {
  font-size: 24rpx;
  color: #9CA3AF;
}

.history-count {
  font-size: 24rpx;
  color: #FF6B6B;
  font-weight: 600;
}

.story-textarea {
  width: 100%;
  min-height: 200rpx;
  background-color: #F9FAFB;
  border-radius: 20rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #2D3748;
  line-height: 1.6;
  border: 2rpx solid #E5E7EB;
  margin-bottom: 20rpx;
}

.story-textarea::placeholder {
  color: #9CA3AF;
}

.submit-btn {
  width: 100%;
  background: linear-gradient(135deg, #FF6B6B 0%, #FFA07A 100%);
  color: #ffffff;
  border: none;
  border-radius: 48rpx;
  padding: 28rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 107, 0.3);
}

.submit-btn:active {
  transform: scale(0.98);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #6B7280;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #9CA3AF;
}

.story-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.story-card {
  background-color: #F9FAFB;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.story-content-wrap {
  flex: 1;
  min-width: 0;
}

.story-content {
  font-size: 28rpx;
  color: #2D3748;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: block;
  white-space: pre-wrap;
}

.story-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.story-date {
  font-size: 24rpx;
  color: #9CA3AF;
}

.story-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.story-status.used {
  background-color: #F3F4F6;
  color: #6B7280;
}

.story-status.unused {
  background-color: #FFF0E6;
  color: #FFA07A;
}

.story-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  position: relative;
  z-index: 100;
}

.action-btn {
  width: 80rpx !important;
  height: 80rpx !important;
  border-radius: 50% !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  font-size: 32rpx !important;
  position: relative !important;
  z-index: 100 !important;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1) !important;
  background: transparent !important;
  border: none !important;
  padding: 0 !important;
  margin: 0 !important;
  overflow: visible !important;
}

.action-btn::after {
  border: none !important;
}

.action-btn.use {
  background-color: #F0FFF4 !important;
}

.action-btn.delete {
  background-color: #FFF5F5 !important;
}

.action-btn:active {
  opacity: 0.8 !important;
  transform: scale(0.9) !important;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15) !important;
}
